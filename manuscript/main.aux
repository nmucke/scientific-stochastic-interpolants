\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Source-covariance approximation ablation for our three samplers on the analytical linear--Gaussian case: KL to the exact posterior versus the number of sampler steps $M$, for the per-member (exact) Jacobian, the shared ensemble-mean Jacobian, and the isotropic Jacobian-free covariance (Corollary\nobreakspace  {}\ref {cor:cheap_drift}). In this linear--Gaussian case the source covariance is state-independent, so the per-member and shared Jacobians \emph  {coincide exactly}; the per-member-vs-shared distinction only matters for a nonlinear prior (the Navier--Stokes and urban cases).\relax }}{26}{figure.caption.31}\protected@file@percent }
\newlabel{fig:analytical_covariance}{{5}{26}{Source-covariance approximation ablation for our three samplers on the analytical linear--Gaussian case: KL to the exact posterior versus the number of sampler steps $M$, for the per-member (exact) Jacobian, the shared ensemble-mean Jacobian, and the isotropic Jacobian-free covariance (Corollary~\ref {cor:cheap_drift}). In this linear--Gaussian case the source covariance is state-independent, so the per-member and shared Jacobians \emph {coincide exactly}; the per-member-vs-shared distinction only matters for a nonlinear prior (the Navier--Stokes and urban cases).\relax }{figure.caption.31}{}}
