\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Graphical abstract: posterior sampling as observation-conditioned transport along one interpolant path.} A pre-trained flow-based prior -- stochastic interpolant (SI), flow matching (FM), or diffusion model (DM) -- transports a tractable source $p_0$ (left) to the forecast prior (right, dashed) over a pseudo-time $\tau $. Conditioning the path on the observation $\bm  {y}^{n}$ tilts its target to the posterior (right, filled): the posterior drift is the prior drift plus a \emph  {single} guidance term $w_\tau \bar  S_\tau $, computed in closed form from the observation interpolant $\bar  {\bm  {y}}_\tau $ with an inflated covariance -- no retraining, no trajectory backpropagation. The diffusion schedule $g_\tau $ indexes a family of provably exact posterior samplers with three practical members.\relax }}{2}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:visual_abstract}{{1}{2}{\textbf {Graphical abstract: posterior sampling as observation-conditioned transport along one interpolant path.} A pre-trained flow-based prior -- stochastic interpolant (SI), flow matching (FM), or diffusion model (DM) -- transports a tractable source $p_0$ (left) to the forecast prior (right, dashed) over a pseudo-time $\tau $. Conditioning the path on the observation $\obs ^{n}$ tilts its target to the posterior (right, filled): the posterior drift is the prior drift plus a \emph {single} guidance term $\gweight _\tau \bar S_\tau $, computed in closed form from the observation interpolant $\interpolantobs _\tau $ with an inflated covariance -- no retraining, no trajectory backpropagation. The diffusion schedule $\gdiff _\tau $ indexes a family of provably exact posterior samplers with three practical members.\relax }{figure.caption.2}{}}
