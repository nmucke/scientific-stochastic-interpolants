\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Choosing the sampler and the likelihood-score approximation from problem geometry.} The diffusion $g_\tau $ selects the sampler (deterministic ODE vs.\ calibrated SDE); the observation regime selects the covariance (cheap Jacobian-free for dense/informative observations, where all samplers nearly coincide, vs.\ the inflated covariance for sparse observations, where it is markedly more accurate); and high dimensionality selects the ensemble-shared evaluation of the source covariance, which removes the per-member cost. The number of steps $M$ and ensemble size $E$ trade accuracy and calibration against cost.\relax }}{24}{figure.caption.26}\protected@file@percent }
\newlabel{fig:decision_guide}{{3}{24}{\textbf {Choosing the sampler and the likelihood-score approximation from problem geometry.} The diffusion $\gdiff _\tau $ selects the sampler (deterministic ODE vs.\ calibrated SDE); the observation regime selects the covariance (cheap Jacobian-free for dense/informative observations, where all samplers nearly coincide, vs.\ the inflated covariance for sparse observations, where it is markedly more accurate); and high dimensionality selects the ensemble-shared evaluation of the source covariance, which removes the per-member cost. The number of steps $M$ and ensemble size $E$ trade accuracy and calibration against cost.\relax }{figure.caption.26}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Model-specific quantities for the observation-interpolant method, instantiated for stochastic interpolants and flow matching. The general framework (left column) treats both as interpolant paths; the model-specific quantities differ only in the source process ${\bm  {\xi }^{\mathrm  {s}}}_\tau $ and how the velocity and score are obtained. The guided ODE and DM-SDE share the flow matching column; the SI-SDE uses the stochastic interpolant column. The source moments and inflated covariance are \emph  {identical} in form for both classes (Lemma\nobreakspace  {}\ref {lem:source_moments}).\relax }}{25}{table.caption.28}\protected@file@percent }
\newlabel{tab:si_vs_fm}{{3}{25}{Model-specific quantities for the observation-interpolant method, instantiated for stochastic interpolants and flow matching. The general framework (left column) treats both as interpolant paths; the model-specific quantities differ only in the source process $\src _\tau $ and how the velocity and score are obtained. The guided ODE and DM-SDE share the flow matching column; the SI-SDE uses the stochastic interpolant column. The source moments and inflated covariance are \emph {identical} in form for both classes (Lemma~\ref {lem:source_moments}).\relax }{table.caption.28}{}}
