\newlabel{fig:analytical_panels}{{4}{31}{Analytical linear--Gaussian case. Top row: prior conditional, likelihood, exact posterior, and a sampled posterior. Bottom row: convergence of the KL divergence to the exact posterior with respect to the diffusion strength and the number of integration steps, and one-dimensional density slices. \textbf {TODO: insert generated figures.}\relax }{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Source-covariance approximation ablation for our three samplers on the analytical linear--Gaussian case: KL to the exact posterior versus the number of sampler steps $M$, for the per-member (exact) Jacobian, the shared ensemble-mean Jacobian, and the isotropic Jacobian-free covariance (Corollary\nobreakspace  {}\ref {cor:cheap_drift}). All three samplers reach the exact posterior (KL $\approx 10^{-3}$) with either the exact or the shared Jacobian, while the isotropic Jacobian-free approximation plateaus at a step-independent bias (KL $\approx 0.9$--$1.4$). In this linear--Gaussian case the source covariance is state-independent, so the per-member and shared Jacobians \emph  {coincide exactly} (their curves overlap); the per-member-vs-shared distinction only matters for a nonlinear prior (the Navier--Stokes and urban cases).\relax }}{31}{figure.caption.29}\protected@file@percent }
\newlabel{fig:analytical_covariance}{{5}{31}{Source-covariance approximation ablation for our three samplers on the analytical linear--Gaussian case: KL to the exact posterior versus the number of sampler steps $M$, for the per-member (exact) Jacobian, the shared ensemble-mean Jacobian, and the isotropic Jacobian-free covariance (Corollary~\ref {cor:cheap_drift}). All three samplers reach the exact posterior (KL $\approx 10^{-3}$) with either the exact or the shared Jacobian, while the isotropic Jacobian-free approximation plateaus at a step-independent bias (KL $\approx 0.9$--$1.4$). In this linear--Gaussian case the source covariance is state-independent, so the per-member and shared Jacobians \emph {coincide exactly} (their curves overlap); the per-member-vs-shared distinction only matters for a nonlinear prior (the Navier--Stokes and urban cases).\relax }{figure.caption.29}{}}
