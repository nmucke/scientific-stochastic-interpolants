GitHub repository available at: https://github.com/Uffe-H-Thygesen/SDEbook and https://github.com/Uffe-H-Thygesen/SDEtools},
	publisher = {Chapman and Hall/CRC},
	author = {Thygesen, Uffe Høgsbro},
	month = jun,
